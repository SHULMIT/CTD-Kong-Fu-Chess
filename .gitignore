# --------------------------------------------------
# Python bytecode and caches
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --------------------------------------------------
# Virtual environments
# --------------------------------------------------
.venv/
venv/
env/
ENV/

# --------------------------------------------------
# Python tooling caches
# --------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/

# --------------------------------------------------
# Test, coverage, and reports
# --------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
*.py,cover

# --------------------------------------------------
# Build and packaging artifacts
# --------------------------------------------------
build/
dist/
site/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# --------------------------------------------------
# Logs and runtime files
# --------------------------------------------------
*.log
*.pid
*.pid.lock
*.out
*.err

# --------------------------------------------------
# Local config and secrets
# --------------------------------------------------
.env
.env.*
*.local

# --------------------------------------------------
# Local databases and dumps
# --------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.dump

# --------------------------------------------------
# IDE / Editor files
# --------------------------------------------------
.vscode/
.idea/
*.iml

# --------------------------------------------------
# OS-generated files
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
# Node / frontend / server future-proofing
# (useful if you add a web server/UI later)
# --------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.parcel-cache/
.next/
.nuxt/
.svelte-kit/

# --------------------------------------------------
# Project-local temporary files
# --------------------------------------------------
.tmp_test29_input.txt
*.tmp
*.temp
